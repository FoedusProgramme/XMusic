<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/expandedPlayerBottomSheet"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clickable="true"
    android:focusable="true"
    android:focusableInTouchMode="true"
    android:clipToOutline="true">

    <com.xapps.media.xmusic.widget.SongCover
        android:id="@+id/covers_pager"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="24dp"
        android:src="@drawable/placeholder"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/song_big_title"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintVertical_weight="1"
        app:layout_constrainedHeight="true"
        app:layout_constrainedWidth="true" />

    <com.xapps.media.xmusic.widget.SmallToggleView
        android:id="@+id/favorite_button"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_marginStart="16dp"
        android:padding="12dp"
        android:scaleType="fitCenter"
        android:background="@drawable/circle_shape"
        android:src="@drawable/ic_favorite_outlined"
        android:tint="?attr/colorOnSurface"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/song_big_title"
        app:layout_constraintBottom_toBottomOf="@+id/artist_big_title" />

    <com.xapps.media.xmusic.widget.MarqueeTextView
        android:id="@+id/song_big_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:paddingTop="5dp"
        android:paddingBottom="2dp"
        android:textSize="22sp"
        android:gravity="center"
        android:textColor="?colorOnSurface"
        app:layout_constraintStart_toEndOf="@+id/favorite_button"
        app:layout_constraintEnd_toStartOf="@+id/save_button"
        app:layout_constraintBottom_toTopOf="@+id/artist_big_title" />

    <com.xapps.media.xmusic.widget.MarqueeTextView
        android:id="@+id/artist_big_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:paddingTop="5dp"
        android:paddingBottom="5dp"
        android:textSize="16sp"
        android:gravity="center"
        android:textColor="?colorOutline"
        app:layout_constraintStart_toEndOf="@+id/favorite_button"
        app:layout_constraintEnd_toStartOf="@+id/save_button"
        app:layout_constraintBottom_toTopOf="@+id/song_seekbar"
        android:layout_marginBottom="24dp" />

    <com.xapps.media.xmusic.widget.SmallToggleView
        android:id="@+id/save_button"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_marginEnd="16dp"
        android:padding="12dp"
        android:scaleType="fitCenter"
        android:background="@drawable/circle_shape"
        android:src="@drawable/ic_playlist_add"
        android:tint="?attr/colorOnSurface"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/song_big_title"
        app:layout_constraintBottom_toBottomOf="@+id/artist_big_title" />

    <com.xapps.media.xmusic.widget.XSeekbar
        android:id="@+id/song_seekbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:enabled="false"
        android:focusable="false"
        android:focusableInTouchMode="false"
        android:progress="0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/current_duration_text"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/current_duration_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="28dp"
        android:textSize="13sp"
        android:textColor="?colorOutline"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/controls_flow"
        android:layout_marginBottom="24dp" />

    <TextView
        android:id="@+id/total_duration_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="28dp"
        android:textSize="13sp"
        android:textColor="?colorOutline"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/controls_flow"
        android:layout_marginBottom="24dp" />

    <androidx.constraintlayout.helper.widget.Flow
        android:id="@+id/controls_flow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:constraint_referenced_ids="previous_button,toggle_view,next_button"
        app:flow_horizontalStyle="packed"
        app:flow_horizontalGap="24dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/song_info_layout"
        android:layout_marginBottom="24dp" />

    <com.xapps.media.xmusic.widget.SmallToggleView
        android:id="@+id/previous_button"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:padding="15dp"
        android:background="@drawable/circle_shape"
        android:src="@drawable/icon_skip_previous_outline"
        android:tint="?attr/colorOnSurface" />

    <com.xapps.media.xmusic.widget.NewPlayerToggle
        android:id="@+id/toggle_view"
        android:layout_width="105dp"
        android:layout_height="105dp"
        android:gravity="center" />

    <com.xapps.media.xmusic.widget.SmallToggleView
        android:id="@+id/next_button"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:padding="15dp"
        android:background="@drawable/circle_shape"
        android:src="@drawable/icon_skip_next_outline"
        android:tint="?attr/colorOnSurface" />

    <LinearLayout
        android:id="@+id/song_info_layout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/pill_rounded"
        android:orientation="vertical"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/frame"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/song_info_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#BDBDBD"
            android:textSize="12sp"
            android:textStyle="bold"
            android:paddingVertical="5dp"
            android:paddingHorizontal="12dp"
            android:text="Unknown" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/frame"
        android:layout_width="0dp"
        android:layout_height="85dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/lyrics_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <com.xapps.media.xmusic.widget.GradientView
                android:id="@+id/mesh"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <FrameLayout
                android:id="@+id/lyrics_placeholder"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <TextView
                    android:id="@+id/placeholder_lyrics_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:text="Hmm, No lyrics found\n¯⁠\⁠\\_⁠(⁠ツ⁠)⁠_⁠/⁠¯"
                    android:textColor="?colorOnSurface"
                    android:alpha="0.85"
                    android:textSize="24dp" />
            </FrameLayout>

            <com.xapps.media.xmusic.widget.XLyricsView
                android:id="@+id/xlyrics_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipChildren="false"
                android:clipToPadding="false" />
        </androidx.constraintlayout.widget.ConstraintLayout>

    </FrameLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
